rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function getCallerData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRestaurantAdmin(restaurantId) {
      let user = getCallerData();
      return isAuthenticated()
        && user.role == 'restaurant_admin'
        && user.restaurantId == restaurantId
        && user.isActive == true;
    }

    function isRestaurantViewUser(restaurantId) {
      let user = getCallerData();
      return isAuthenticated()
        && user.role == 'restaurant_view'
        && user.restaurantId == restaurantId
        && user.isActive == true;
    }

    function isOwnerOrSuperAdmin(restaurantId) {
      return isSuperAdmin() || isRestaurantAdmin(restaurantId);
    }

    function canAccessRestaurant(restaurantId) {
      return isOwnerOrSuperAdmin(restaurantId) || isRestaurantViewUser(restaurantId);
    }

    // ─── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Cada usuario puede leer su propio doc; super admin lee todos;
      // restaurant_admin puede leer view users de su mismo restaurante
      allow read: if isAuthenticated() && (
        request.auth.uid == userId
        || isSuperAdmin()
        || (
          getCallerData().role == 'restaurant_admin'
          && resource.data.restaurantId == getCallerData().restaurantId
          && resource.data.role == 'restaurant_view'
        )
      );

      // Super admin puede todo; restaurant_admin puede crear/actualizar/eliminar
      // view users de su propio restaurante
      allow create: if isSuperAdmin() || (
        getCallerData().role == 'restaurant_admin'
        && request.resource.data.restaurantId == getCallerData().restaurantId
        && request.resource.data.role == 'restaurant_view'
      );

      allow update, delete: if isSuperAdmin() || (
        getCallerData().role == 'restaurant_admin'
        && resource.data.restaurantId == getCallerData().restaurantId
        && resource.data.role == 'restaurant_view'
      );
    }

    // ─── Restaurants ───────────────────────────────────────────────────────────

    match /restaurants/{restaurantId} {
      // El menú público necesita leer el restaurante (sin auth)
      allow read: if true;

      // Solo super admin puede crear/actualizar/eliminar restaurantes
      allow create, delete: if isSuperAdmin();
      allow update: if isOwnerOrSuperAdmin(restaurantId);

      // ─── Order Statuses ──────────────────────────────────────────────────────

      match /orderStatuses/{statusId} {
        allow read: if true;
        // Solo admin puede crear/modificar/eliminar estados
        allow write: if isOwnerOrSuperAdmin(restaurantId);
      }

      // ─── Categories ──────────────────────────────────────────────────────────

      match /categories/{categoryId} {
        // El menú público necesita leer categorías
        allow read: if true;
        allow write: if isOwnerOrSuperAdmin(restaurantId);
      }

      // ─── Products ────────────────────────────────────────────────────────────

      match /products/{productId} {
        // El menú público necesita leer productos
        allow read: if true;
        allow write: if isOwnerOrSuperAdmin(restaurantId);
      }

      // ─── Adicionales ─────────────────────────────────────────────────────────

      match /adicionales/{adicionalId} {
        allow read: if true;
        allow write: if isOwnerOrSuperAdmin(restaurantId);
      }

      // ─── Delivery Zones ──────────────────────────────────────────────────────

      match /deliveryZones/{zoneId} {
        // El menú público necesita leer zonas para el checkout
        allow read: if true;
        allow write: if isOwnerOrSuperAdmin(restaurantId);
      }

      // ─── Domiciliarios ───────────────────────────────────────────────────────

      match /domiciliarios/{domiciliarioId} {
        allow read: if canAccessRestaurant(restaurantId);
        allow write: if isOwnerOrSuperAdmin(restaurantId);
      }

      // ─── Orders ──────────────────────────────────────────────────────────────

      match /orders/{orderId} {
        // Clientes pueden crear pedidos (checkout WhatsApp alternativo vía Firestore)
        // Admin y view users pueden leer y actualizar (cambiar estado)
        allow create: if true;
        allow read, update: if canAccessRestaurant(restaurantId);
        // Nadie elimina pedidos — solo se cambia el estado
        allow delete: if isSuperAdmin();
      }
    }
  }
}
